{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nutritionix/refs/heads/main/json-structure/track-branded-food-structure.json",
  "name": "BrandedFood",
  "description": "A matched branded or restaurant food from instant search.",
  "type": "object",
  "properties": {
    "food_name": {
      "type": "string",
      "example": "Big Mac"
    },
    "serving_unit": {
      "type": "string",
      "example": "burger"
    },
    "nix_brand_id": {
      "type": "string",
      "example": "513fbc1283aa2dc80c000053"
    },
    "brand_name_item_name": {
      "type": "string",
      "example": "McDonald's Big Mac"
    },
    "serving_qty": {
      "type": "double",
      "example": 1
    },
    "nf_calories": {
      "type": "double",
      "example": 540
    },
    "photo": {
      "$ref": "#/components/schemas/Photo"
    },
    "brand_name": {
      "type": "string",
      "example": "McDonald's"
    },
    "region": {
      "type": "int32",
      "example": 1
    },
    "brand_type": {
      "type": "int32",
      "example": 1
    },
    "nix_item_id": {
      "type": "string",
      "example": "513fc9e73fe3ffd40300109f"
    },
    "locale": {
      "type": "string",
      "example": "en_US"
    }
  }
}