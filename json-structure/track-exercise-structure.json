{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nutritionix/refs/heads/main/json-structure/track-exercise-structure.json",
  "name": "Exercise",
  "description": "A single analyzed physical activity.",
  "type": "object",
  "properties": {
    "tag_id": {
      "type": "int32",
      "description": "Internal exercise tag identifier."
    },
    "user_input": {
      "type": "string",
      "description": "The portion of the query that mapped to this exercise."
    },
    "duration_min": {
      "type": "double",
      "description": "Duration of the activity in minutes.",
      "example": 30
    },
    "met": {
      "type": "double",
      "description": "Metabolic Equivalent of Task value for the activity.",
      "example": 9.8
    },
    "nf_calories": {
      "type": "double",
      "description": "Estimated calories burned.",
      "example": 372.5
    },
    "photo": {
      "$ref": "#/components/schemas/Photo"
    },
    "compendium_code": {
      "type": "int32",
      "description": "Compendium of Physical Activities code for the exercise."
    },
    "name": {
      "type": "string",
      "description": "Canonical name of the activity.",
      "example": "running"
    },
    "benefits": {
      "type": "string",
      "nullable": true,
      "description": "Optional notes on the benefits of the activity."
    }
  }
}